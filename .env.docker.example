# This file shows the Docker env values for local container runs.
# Edit this file when Docker needs another env variable or Docker URL.
# Copy this file to .env.docker when you want to run the Docker stack locally.
APP_MODE=dev
COOKIE_SECRET=local-docker-secret
FRONTEND_ORIGIN=http://localhost:8088
PUBLIC_BASE_URL=http://localhost:8089
OIDC_ISSUER_URL=
OIDC_INTERNAL_BASE_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
FRONTEND_PORT=8088
BACKEND_PORT=8089
VITE_BACKEND_URL=http://localhost:8089
